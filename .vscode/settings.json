{
  "cmake.sourceDirectory": "${workspaceFolder}",
  "cmake.buildDirectory":  "${workspaceFolder}/build",
  "cmake.configureOnOpen": false,
  "files.associations": {
    "*.h.in": "cpp",
    "InitGui.py": "python",
    "Init.py":    "python"
  },
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/milcam/CodesysBridge/inc",
    "/usr/include/python3*",
    "/home/embed/Downloads/FreeCAD-main-1-1-git/src"
  ],
  "python.analysis.extraPaths": [
    "${workspaceFolder}/milcam/Mod/MilCAM",
    "${workspaceFolder}/milcam/Mod/MilCAM/PostProcessor",
    "/home/embed/Downloads/FreeCAD-main-1-1-git/src/Mod/CAM"
  ],
  "files.trimTrailingWhitespace": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.exclude": {
    "build":      true,
    "build-*":    true,
    "install":    true,
    "install-*":  true,
    "_inst":      true,
    "**/__pycache__": true,
    "**/.pytest_cache": true
  }
}
