{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MilCAM configure",
      "type": "shell",
      "command": "cmake --preset default",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "MilCAM build",
      "type": "shell",
      "command": "cmake --build build -j$(nproc)",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": [ "$gcc" ]
    },
    {
      "label": "MilCAM tests",
      "type": "shell",
      "command": "ctest --test-dir build --output-on-failure",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "MilCAM run",
      "type": "shell",
      "command": "DISPLAY=:0 QT_QPA_PLATFORM=xcb ./build/milcam",
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": "MilCAM build"
    },
    {
      "label": "MilCAM cross-build (panel-pc)",
      "type": "shell",
      "command": "cmake --preset panel-pc && cmake --build build-aarch64 -j$(nproc)",
      "options": { "cwd": "${workspaceFolder}" }
    }
  ]
}
