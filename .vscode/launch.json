{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run installed MilCAM (FreeCAD)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/_inst/usr/local/bin/FreeCAD",
      "args": [],
      "cwd": "${workspaceFolder}",
      "environment": [
        { "name": "DISPLAY",         "value": ":0" },
        { "name": "QT_QPA_PLATFORM", "value": "xcb" },
        { "name": "QT_IM_MODULE",    "value": "qtvirtualkeyboard" }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "MilCAM install (DESTDIR=_inst)"
    },
    {
      "name": "pytest (overlay-only)",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [ "-v", "tests/python" ],
      "cwd": "${workspaceFolder}"
    }
  ]
}
